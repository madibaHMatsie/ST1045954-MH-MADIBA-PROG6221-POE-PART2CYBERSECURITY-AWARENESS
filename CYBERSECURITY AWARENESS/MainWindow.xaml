<Window x:Class="CYBERSECURITY_AWARENESS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CYBERSECURITY_AWARENESS"
        mc:Ignorable="d"
        Title="CYBERBOT- CYBERSECURITY AWARENES CHATBOT" 
		Height="700" Width="900"
		WindowStartupLocation="CenterScreen"
        Background="#FFD1DC">

	<Window.Resources>
		<!-- Colour -->
		<SolidColorBrush x:Key="PrimaryColor" Color="#FF69B4"/>
		
		<SolidColorBrush x:Key="SecondaryColor" Color="#FF1493"/>
		
		<SolidColorBrush x:Key="UserBubbleColor" Color="#FF85B3"/>
		
		<SolidColorBrush x:Key="BotBubbleColor" Color="#FFF0F5"/>
		
		<SolidColorBrush x:Key="BackgroundColor" Color="#FFD1DC"/>
		
		<SolidColorBrush x:Key="InputBackground" Color="#FFE4E1"/>
		

		<!--  User Messages -->
		<Style x:Key="UserMessageStyle" TargetType="Border">
			<Setter Property="Background" Value="{StaticResource UserBubbleColor}"/>
			<Setter Property="CornerRadius" Value="15,15,5,15"/>
			<Setter Property="Padding" Value="12,8"/>
			<Setter Property="Margin" Value="50,5,10,5"/>
			<Setter Property="HorizontalAlignment" Value="Right"/>
		</Style>

		<!--  Bot Messages -->
		<Style x:Key="BotMessageStyle" TargetType="Border">
			<Setter Property="Background" Value="{StaticResource BotBubbleColor}"/>
			<Setter Property="CornerRadius" Value="15,15,15,5"/>
			<Setter Property="Padding" Value="12,8"/>
			<Setter Property="Margin" Value="10,5,50,5"/>
			<Setter Property="HorizontalAlignment" Value="Left"/>
		</Style>
	</Window.Resources>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- Header with ASCII Art - -->
		<Border Grid.Row="0" Background="{StaticResource PrimaryColor}" Padding="10">
			<StackPanel>

				<TextBlock Text="__  _    ___  ____ ___  ___  ________" FontFamily="Consolas" FontSize="10" Foreground="White" TextAlignment="Center"/>
				<TextBlock Text="/ /`\\ \\_/| |_)| |_ | |_)| |_)/ / \\| |" FontFamily="Consolas" FontSize="10" Foreground="White" TextAlignment="Center"/>
				<TextBlock Text="\\_\\_,|_| |_|_)|_|__|_| \\|_|_)\\_\\_/|_|" FontFamily="Consolas" FontSize="10" Foreground="White" TextAlignment="Center"/>
				<TextBlock Text="                    [LOCK]                    "
                           FontFamily="Consolas" FontSize="12" Foreground="#FFE6F0" 
                           TextAlignment="Center"/>
				<TextBlock Text="         Your Digital Safety Companion         "
                           FontFamily="Consolas" FontSize="11" Foreground="#FFF0F5" 
                           TextAlignment="Center"/>
				
			</StackPanel>
		</Border>

		<!-- Info Bar - -->
		<Border Grid.Row="1" Background="{StaticResource SecondaryColor}" Padding="8,5">
			<StackPanel Orientation="Horizontal">
				<TextBlock Text="👤 User: " Foreground="White" FontWeight="Bold"/>
				<TextBlock x:Name="UserNameText" Text="Guest" Foreground="#FFE6F0" FontWeight="Bold"/>
				<TextBlock Text=" | Interest: " Foreground="White" FontWeight="Bold" Margin="20,0,0,0"/>
				<TextBlock x:Name="UserInterestText" Text="None" Foreground="#FFE6F0" FontWeight="Bold"/>
				<TextBlock Text=" | Mood: " Foreground="White" FontWeight="Bold" Margin="20,0,0,0"/>
				<TextBlock x:Name="UserMoodText" Text="Neutral" Foreground="#FFE6F0" FontWeight="Bold"/>
			</StackPanel>
		</Border>

		<!-- Chat Messages - -->
		<ScrollViewer Grid.Row="1" x:Name="ChatScrollViewer" 
                      VerticalScrollBarVisibility="Auto"
                      Background="{StaticResource BackgroundColor}" Margin="0,24,0,2" Grid.RowSpan="2">
			<StackPanel x:Name="ChatMessagesPanel" Margin="10" Orientation="Vertical"/>
		</ScrollViewer>

		<!-- Input Section-->
		<Border Grid.Row="3" Background="{StaticResource InputBackground}" Padding="10">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>

				<TextBox x:Name="InputTextBox" 
                         FontSize="14" 
                         Foreground="#333333" 
                         Background="White"
                         BorderBrush="{StaticResource PrimaryColor}"
                         BorderThickness="2"
                         Padding="10,8"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         KeyDown="InputTextBox_KeyDown">
					<TextBox.Resources>
						<Style TargetType="{x:Type Border}">
							<Setter Property="CornerRadius" Value="20"/>
						</Style>
					</TextBox.Resources>
				</TextBox>

				<Button Grid.Column="1" 
                        x:Name="SendButton"
                        Content="SEND" 
                        Width="80" Height="40"
                        Margin="10,0,0,0"
                        Background="{StaticResource PrimaryColor}"
                        Foreground="White"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Click="SendButton_Click">
					<Button.Resources>
						<Style TargetType="{x:Type Border}">
							<Setter Property="CornerRadius" Value="20"/>
						</Style>
					</Button.Resources>
				</Button>
			</Grid>
		</Border>

		<!-- Status -->
		<StatusBar Grid.Row="3" VerticalAlignment="Bottom" Background="{StaticResource SecondaryColor}" Height="25" Margin="0,0,0,0">
			<StatusBarItem>
				<TextBlock x:Name="StatusText" Text="Ready" Foreground="White" FontSize="10"/>
			</StatusBarItem>
			<StatusBarItem HorizontalAlignment="Right">
				<TextBlock x:Name="VoiceStatusText" Text="🎤 Voice: Ready" Foreground="#FFE6F0" FontSize="10"/>
			</StatusBarItem>
		</StatusBar>
	</Grid>
</Window>
